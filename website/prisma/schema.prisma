datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commands    Command[]
  subspaces   Subspace[]
  workflows   Workflow[]
  tickets     SupportTicket[]
}

model Command {
  id        String   @id @default(cuid())
  prompt    String
  provider  String
  model     String?
  output    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Subspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("active")
  config      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  workflows Workflow[]
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  steps       String?
  status      String   @default("idle")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  subspaceId  String?
  subspace    Subspace? @relation(fields: [subspaceId], references: [id])
}

model SupportTicket {
  id        String   @id @default(cuid())
  subject   String
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String
  category  String?
  tags      String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    String   @default("OpenForge Team")
}
