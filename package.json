{
  "name": "@openforge-cli",
  "version": "1.0.0",
  "description": "OpenForge - AI-powered Desktop Assistant & CLI",
  "bin": {
    "openforge": "bin/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Frosty427/OpenForge.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "postinstall": "npm install -g openforge@latest",
    "start": "npm install -g openforge@latest && openforge gateway",
    "gateway": "node bin/cli.js gateway",
    "node": "node bin/cli.js node",
    "tui": "node bin/cli.js tui",
    "dashboard": "npm run dev",
    "config": "node bin/cli.js config",
    "configure": "node bin/cli.js configure",
    "setup": "node bin/cli.js setup",
    "doctor": "node bin/cli.js doctor",
    "update": "npm install -g openforge@latest",
    "reset": "node bin/cli.js reset",
    "status": "node bin/cli.js status",
    "health": "node bin/cli.js health",
    "logs": "node bin/cli.js logs",
    "docs": "node bin/cli.js docs",
    "completion": "node bin/cli.js completion",
    "qr": "node bin/cli.js qr",
    "onboard": "node bin/cli.js onboard",
    "uninstall": "node bin/cli.js uninstall"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron-is-dev": "^3.0.1",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "openai": "^6.32.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
