{
    "name": "file_ops",
    "version": "0.1.0",
    "description": "Safe file operations plugin.",
    "author": "OpenForge Contributors",
    "enabled": true,
    "entry_point": "main.py",
    "permissions": ["read_files"],
    "tools": [
        {
            "name": "list_files",
            "description": "List all files in a specific directory (relative to project root).",
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "Directory path to list (e.g. '.' or 'src/'). Cannot contain '..'."
                    }
                },
                "required": ["path"]
            }
        },
        {
            "name": "read_file",
            "description": "Read the text contents of a file (relative to project root).",
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "File path to read (e.g. 'README.md'). Cannot contain '..'."
                    }
                },
                "required": ["path"]
            }
        }
    ]
}
